# Supabase project
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_XXXXXXXXXXXX"

# Prisma — pooled connection (used by Prisma at runtime)
# For Supabase Transaction Pooler, add connection pool params:
#   ?pgbouncer=true&connection_limit=10&pool_timeout=20
# Example: postgresql://postgres:PASS@HOST:6543/postgres?pgbouncer=true&connection_limit=10&pool_timeout=20
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

# Prisma — direct connection (used by Prisma migrations)
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

# JWT
JWT_SECRET="change-me-strong-random-secret"
JWT_REFRESH_SECRET="change-me-strong-random-refresh-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# App
PORT=3000
NODE_ENV=development

# Swagger (optional)
SWAGGER_ENABLED=true
SWAGGER_USER=admin
SWAGGER_PASSWORD=secret

# Mapbox (geocoding)
MAPBOX_ACCESS_TOKEN=pk.eyJ1IjoiTU9ESUZJQ0FfVFVfVE9LRU4iLCJhIjoiIn0.XXXXXXXXXXXXXXXXXXXXXXXX
MAPBOX_COUNTRY=co
MAPBOX_PROXIMITY_LNG=-73.122742
MAPBOX_PROXIMITY_LAT=7.119349

# Redis (optional - for distributed cache)
REDIS_URL=""

# Firebase Admin SDK (notificaciones push FCM)
# Obtén estas credenciales en Firebase Console → Configuración del proyecto → Cuentas de servicio
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXXXX\n-----END PRIVATE KEY-----\n"
