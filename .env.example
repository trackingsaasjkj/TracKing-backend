# Supabase PostgreSQL — pooled connection (used by Prisma at runtime)
DATABASE_URL="postgresql://USER:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

# Supabase PostgreSQL — direct connection (used by Prisma migrations)
DIRECT_URL="postgresql://USER:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

# JWT
JWT_SECRET="change-me-strong-random-secret"
JWT_REFRESH_SECRET="change-me-strong-random-refresh-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# App
PORT=3000
NODE_ENV=development
